# Absolute path to the vault root (parent of the wiki/ directory)
VAULT_ROOT=/Users/you/path/to/pkm

# AI provider defaults
DEFAULT_AI_PROVIDER=ollama
DEFAULT_OLLAMA_MODEL=llama3.2
DEFAULT_OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
# Max output tokens per chat reply, per provider (cloud is clamped to the model's real
# output limit). Set CHAT_MAX_TOKENS to override both at once.
CHAT_MAX_TOKENS_OLLAMA=4096
CHAT_MAX_TOKENS_OPENROUTER=64000
# CHAT_MAX_TOKENS=8192

# Connection
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENROUTER_API_KEY=

# Semantic search (phase 2) — Ollama embeddings + Neo4j vector index
# OLLAMA_NATIVE_URL defaults to OLLAMA_BASE_URL without the /v1 suffix
OLLAMA_NATIVE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# Server
PORT=3000
